{
  "name": "crawler",
  "displayName": "Crawler",
  "description": "Agentic code scanner that finds bugs, generates fixes, and lets you apply patches.",
  "version": "1.0.0",
  "publisher": "ab",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:crawler.scan",
    "onCommand:crawler.applyFix",
    "onCommand:crawler.explainIssue",
    "onCommand:crawler.addLocalProvider",
    "onCommand:crawler.addApiProvider",
    "onCommand:crawler.benchmarkProviders",
    "onView:crawlerSidebar"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crawler.scan",
        "title": "Crawler: Scan Workspace"
      },
      {
        "command": "crawler.applyFix",
        "title": "Crawler: Apply Selected Fix"
      },
      {
        "command": "crawler.explainIssue",
        "title": "Crawler: Explain Selected Issue"
      },
      {
        "command": "crawler.addLocalProvider",
        "title": "Crawler: Add Local Provider"
      },
      {
        "command": "crawler.addApiProvider",
        "title": "Crawler: Add API Provider"
      },
      {
        "command": "crawler.benchmarkProviders",
        "title": "Crawler: Benchmark Providers"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "crawlerSidebar",
          "name": "Crawler"
        }
      ]
    },
    "configuration": {
      "title": "Crawler",
      "properties": {
        "crawler.providers": {
          "type": "array",
          "default": [],
          "description": "Configured model providers for Crawler (local and API).",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "local",
                  "api"
                ]
              },
              "port": {
                "type": "number",
                "description": "Local model port (for type=local)."
              },
              "model": {
                "type": "string",
                "description": "Model name."
              },
              "name": {
                "type": "string",
                "description": "API provider name (for type=api)."
              },
              "baseUrl": {
                "type": "string",
                "description": "Base URL for API provider."
              },
              "apiKey": {
                "type": "string",
                "description": "API key (optional)."
              },
              "headers": {
                "type": "object",
                "description": "Custom headers for API provider."
              },
              "params": {
                "type": "object",
                "description": "Extra params (temperature, max_tokens, etc.)."
              }
            }
          }
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ."
  },
  "dependencies": {
    "diff": "^5.2.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.125.0",
    "typescript": "^5.9.3"
  }
}
